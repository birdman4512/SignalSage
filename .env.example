# ── Slack ──────────────────────────────────────────────────────────────────
SLACK_BOT_TOKEN=xoxb-your-slack-bot-token
SLACK_APP_TOKEN=xapp-your-slack-app-token

# ── Discord (optional) ──────────────────────────────────────────────────────
DISCORD_BOT_TOKEN=your-discord-bot-token

# ── Threat Intel API Keys ───────────────────────────────────────────────────
# Leave blank to disable that provider (free providers need no key at all)
VT_API_KEY=
SHODAN_API_KEY=
GREYNOISE_API_KEY=
ABUSEIPDB_API_KEY=
OTX_API_KEY=
IPINFO_API_KEY=
ABUSECH_API_KEY=    # Free key from https://auth.abuse.ch — used by URLhaus + ThreatFox

# ── LLM for daily digest ────────────────────────────────────────────────────
# "ollama"    — local, free (default). Requires Ollama running on your machine.
# "anthropic" — paid Claude API.
LLM_PROVIDER=ollama

# Ollama settings (used when LLM_PROVIDER=ollama)
# If running Ollama via docker-compose --profile ollama, use: http://ollama:11434
# If running Ollama on your host machine separately, use:    http://localhost:11434
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=gemma2:2b

# Anthropic settings (only needed when LLM_PROVIDER=anthropic)
ANTHROPIC_API_KEY=
